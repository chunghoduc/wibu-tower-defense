{
  "name": "wibu-tower-defense",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Collectible lane-based tower defense — web-first (Phaser 3 + TypeScript), portable to mobile via Capacitor.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "gen:sprites": "vite-node scripts/sdart/sdgen.mjs",
    "gen:sprites:anim": "vite-node scripts/sdart/animgen.mjs",
    "gen:item-visual": "vite-node scripts/genItemVisual.ts",
    "gen:skill-visual": "vite-node scripts/genSkillVisual.ts"
  },
  "dependencies": {
    "phaser": "^3.80.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "prettier": "^3.8.4",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vitest": "^2.0.5"
  }
}
