{
  "name": "wibu-tower-defense",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Collectible lane-based tower defense — web-first (Phaser 3 + TypeScript), portable to mobile via Capacitor.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen:art-prompts": "vite-node scripts/genArtPrompts.ts"
  },
  "dependencies": {
    "phaser": "^3.80.1"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vitest": "^2.0.5"
  }
}
